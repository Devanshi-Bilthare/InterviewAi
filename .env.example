# MongoDB Atlas M0 (free tier)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/ai-interview-platform

# NextAuth (free, self-hosted)
NEXTAUTH_SECRET=generate-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# Google Gemini — free via Google AI Studio (use gemini-2.5-flash or gemini-2.5-flash-lite)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# Groq Whisper — free tier (~6000 audio min/month, no credit card)
# Get key: https://console.groq.com
GROQ_API_KEY=

# Cloudinary — free tier (25GB storage, 25GB bandwidth/month)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Code execution — free Judge0 CE (no API key needed)
# JUDGE0_API_URL=https://ce.judge0.com
# Piston public API is whitelist-only; use Judge0 CE instead

# Resend — free tier (3000 emails/month)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional: Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Deprecated — do not use (paid)
# OPENAI_API_KEY=
# JUDGE0_API_KEY=
# JUDGE0_RAPIDAPI_KEY=
